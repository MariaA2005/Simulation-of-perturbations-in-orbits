% -------------------------------------------------------------------------
%% IMPORTS
% -------------------------------------------------------------------------

% -------------------------------------------------------------------------
%% DEFINITIONS
% -------------------------------------------------------------------------
 
%% Initial conditions
v_orbital = sqrt(Gr * m1 / radio_orbita); 

state0.R10 = [0; 0; 0];                    
state0.R20 = [radio_orbita; 0; 0];         
state0.V10 = [0; 0; 0];                    
state0.V20 = [0; v_orbital * cos(deg2rad(constant.inc0)); v_orbital * sin(deg2rad(constant.inc0))]; 
tf = 2*24 * 3600; 

% -------------------------------------------------------------------------
%% OBTAIN DATA
% -------------------------------------------------------------------------
%% Orbits
[t, states_m, acc] = two_body_integration(constant, state0, tf); 
[tJ2, statesJ2_m, accJ2] = two_body_integration(constant, state0, tf, J2);
[tLS, statesLS_m, accLS] = two_body_integration(constant, state0, tf, 0, true);
orbitNominal = getOrbitData(states_m, t, acc); 
orbitJ2 = getOrbitData(statesJ2_m, tJ2, accJ2);
orbitLS = getOrbitData(statesLS_m, tLS, accLS); 
%% Sensors
% -------------------------------------------------------------------------
simula
%% KALMAN FILTER
% -------------------------------------------------------------------------
% -------------------------------------------------------------------------
%% PID
% -------------------------------------------------------------------------
% -------------------------------------------------------------------------
%% CORRECT ORBITS
% -------------------------------------------------------------------------
% -------------------------------------------------------------------------
%% GRAFICAS
% -------------------------------------------------------------------------

%% 4. Visualización y Comparación 3D
plot3D(orbitNominal.radius, orbitJ2.radius, orbitLS.radius); 

%% 5. Diferencia Radial (Corregido con Interpolación)
plotDifRadial(orbitNominal, orbitJ2, orbitLS); 
%% radius and inc
plotIncRadius(orbitNominal,orbitJ2, orbitLS);